# Supabase (für Backoffice-Login, Buchungen, Anmeldungen)
# Projekt-URL und Keys: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SEO / Domain (Production)
# Exakt die öffentliche URL: https + Domain, ohne Pfad und ohne Slash am Ende (für Canonical-URLs & Schema.org).
# Beispiel: https://maryosfahrschule.de
NEXT_PUBLIC_SITE_URL=

# Optional: Sanity (Blog), Resend (E-Mails), Stripe (Zahlungen), Plausible
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# RESEND_API_KEY=
# RESEND_FROM=
# CONTACT_EMAIL=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: Stripe Dashboard → Developers → Webhooks → URL https://<domain>/api/stripe/webhook
# Event: payment_intent.succeeded — Signing secret hier eintragen:
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
