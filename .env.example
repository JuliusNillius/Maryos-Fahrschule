# Supabase (für Backoffice-Login, Buchungen, Anmeldungen)
# Projekt-URL und Keys: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: schnellerer lokaler `npm run build` — überspringt Supabase während der Build-Phase (keine Wartezeit/Timeouts).
# Nur in .env.local; auf Vercel/Production nicht setzen.
# SKIP_BUILD_SUPABASE=1

# SEO / Domain (Production)
# Exakt die öffentliche URL: https + Domain, ohne Pfad und ohne Slash am Ende (für Canonical-URLs & Schema.org).
# Beispiel: https://maryosfahrschule.de
NEXT_PUBLIC_SITE_URL=

# Optional: Google Business Profile / Maps-Listing (volle URL, z. B. https://maps.app.goo.gl/… oder https://g.page/…)
# Im GBP-Dashboard „Teilen“ oder in Google Maps am Eintrag „Link teilen“. Wird ins JSON-LD (sameAs / hasMap) eingetragen.
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=

# Optional: Sanity (Blog), Resend (E-Mails), Stripe (Zahlungen), Plausible
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# RESEND_API_KEY=
# RESEND_FROM=
# CONTACT_EMAIL=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: Stripe Dashboard → Developers → Webhooks → URL https://<domain>/api/stripe/webhook
# Event: payment_intent.succeeded — Signing secret hier eintragen:
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Production: Content-Security-Policy (next.config.js). Bei Konflikten mit Drittanbietern auf 1 setzen:
# CSP_DISABLE=1

# Hero-Videos: Option A — Supabase Storage (Bucket hero-videos, siehe docs/hero-videos-supabase.md)
# Leer lassen = lokale Dateien public/videos/hero.mp4 + hero-mobile.mp4
# NEXT_PUBLIC_HERO_VIDEO_DESKTOP_URL=https://<projekt-ref>.supabase.co/storage/v1/object/public/hero-videos/hero.mp4
# NEXT_PUBLIC_HERO_VIDEO_MOBILE_URL=https://<projekt-ref>.supabase.co/storage/v1/object/public/hero-videos/hero-mobile.mp4
