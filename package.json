    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "npm run build && npx lighthouse http://localhost:3000 --view --output=html --output-path=./lighthouse-report.html --chrome-flags='--headless' || true"
  },
